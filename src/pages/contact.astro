---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Contact Corbin Riches by email.">
	<section class="page-header">
		<p class="eyebrow">contact</p>
		<h1>Say hello.</h1>
		<p>
			For project questions, engineering opportunities, technical writing, or anything that
			seems adjacent to this site, email is the best place to start.
		</p>
	</section>

	<section class="section contact-grid">
		<article class="project-card">
			<p class="eyebrow">main email</p>
			<h2><a href="mailto:corbin@corbinriches.com">corbin@corbinriches.com</a></h2>
			<p>Use this address for direct contact, portfolio-related notes, and opportunities.</p>
		</article>
		<article class="project-card">
			<p class="eyebrow">general contact</p>
			<h2><a href="mailto:info@corbinriches.com">info@corbinriches.com</a></h2>
			<p>Use this address for general website or administrative contact.</p>
		</article>
	</section>
</Layout>
