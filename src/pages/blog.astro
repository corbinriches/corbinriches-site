---
import Layout from '../layouts/Layout.astro';
import {
	formatPostDate,
	getPostSlug,
	getPublishedPosts,
	getReadingTime,
	getTagSummaries,
	slugifyTag,
} from '../utils/blog';

const posts = await getPublishedPosts();
const tags = getTagSummaries(posts);
---

<Layout title="Blog" description="Technical notes and short essays from Corbin Riches.">
	<section class="page-header">
		<p class="eyebrow">blog</p>
		<h1>Notes and project logs.</h1>
		<p>
			This section is for technical writing, project updates, derivations, reading notes, and
			short explanations that are useful enough to keep.
		</p>
		{tags.length > 0 && <p class="blog-tag-nav"><a href="/blog/tags/">browse tags</a></p>}
	</section>

	<section class="section">
		{
			posts.length > 0 ? (
				<div class="post-list">
					{posts.map((post) => (
						<article class="post-card">
							<p class="eyebrow">{getReadingTime(post.body)}</p>
							<h2><a href={`/blog/${getPostSlug(post)}/`}>{post.data.title}</a></h2>
							<div class="post-meta">
								<time datetime={post.data.date.toISOString()}>
									{formatPostDate(post.data.date)}
								</time>
								{post.data.tags.length > 0 && (
									<ul class="tag-list" aria-label={`${post.data.title} tags`}>
										{post.data.tags.map((tag) => (
											<li><a href={`/blog/tags/${slugifyTag(tag)}/`}>{tag}</a></li>
										))}
									</ul>
								)}
							</div>
							<p>{post.data.description}</p>
						</article>
					))}
				</div>
			) : (
				<div class="empty-state">
					<p class="eyebrow">draft queue</p>
					<h2>First posts are still being assembled.</h2>
					<p>Likely topics include quantum dot modeling, simulation habits, and photonics references.</p>
				</div>
			)
		}
	</section>
</Layout>
