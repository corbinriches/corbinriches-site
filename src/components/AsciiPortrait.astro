---
const {
	label = 'ascii portrait',
	caption = 'placeholder portrait block / replace me later',
	art = String.raw`
+--------------------------------+
|          CORBIN RICHES         |
|                                |
|      .------------------.      |
|      |  eng physics     |      |
|      |  photonics       |      |
|      |  cryo / sim      |      |
|      '------------------'      |
|                                |
|          [ ascii face ]        |
|          [ goes here  ]        |
+--------------------------------+
       /|                |\
      /_|  notes, labs   |_\
        |  projects      |
        '----------------'
`.trim(),
} = Astro.props;
---

<figure class="ascii-panel ascii-portrait" aria-label={label}>
	<pre>{art}</pre>
	<figcaption>{caption}</figcaption>
</figure>
